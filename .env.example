# OpenAI API (text generation)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Kie.ai API (image generation only)
KIE_AI_API_KEY=your-kie-ai-api-key
KIE_AI_BASE_URL=https://api.kie.ai
# Image model (Nano Banana Pro)
KIE_AI_IMAGE_MODEL=nano-banana-pro

# Telegram (post to channel and for admin approval)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel
ADMIN_ID=your-admin-id

# VK (wall post)
VK_ACCESS_TOKEN=your-vk-access-token
VK_GROUP_ID=your-vk-group-id

# Scheduler: cron expression (default 10:00 daily). Set RUN_ONCE=true to run once and exit.
POST_CRON=0 10 * * *
RUN_ONCE=

# Optional: state file path (default: state.json in project root)
# STATE_PATH=./state.json

# Dry run: generate text + image, do NOT post to TG/VK and do NOT update state
# DRY_RUN=true
